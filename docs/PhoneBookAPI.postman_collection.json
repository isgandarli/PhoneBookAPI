							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/phonebook",
							"host": ["{{base_url}}"],
							"path": ["phonebook"]
						},
						"description": "Public endpoint. Returns all employees with their position and structure (including structure type). No authentication required."
					},
					"response": []
				}
			],
			"description": "Public-facing phonebook endpoint. No authentication required."
		},
